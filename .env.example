# ─── Application ──────────────────────────────────────────────
APP_ENV=local
APP_SECRET_KEY=change-me-in-production

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tournament:tournament@db:5432/tournament_hub
POSTGRES_USER=tournament
POSTGRES_PASSWORD=tournament
POSTGRES_DB=tournament_hub

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Auth ─────────────────────────────────────────────────────
# Comma-separated list of allowed email domains (empty = allow all)
ALLOWED_EMAIL_DOMAINS=

# ─── SMTP (local: Mailpit on ports 1025/8025) ────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@company.com
SMTP_TLS_ENABLED=false

# ─── External Soccer API ─────────────────────────────────────
SOCCER_API_KEY=
SOCCER_API_PROVIDER=football-data

# ─── Feature Configuration ───────────────────────────────────
DUEL_INVITE_EXPIRY_HOURS=24
COMMENT_GRACE_PERIOD_MINUTES=5
DEFAULT_LOCKOUT_HOURS=1.0

# ─── Avatar Storage ──────────────────────────────────────────
AVATAR_STORAGE=local
AVATAR_LOCAL_PATH=/app/avatars
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
